# Audiobook service environment

API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501
STORAGE_DIR=./storage
MAX_UPLOAD_MB=200
MAX_CONCURRENT_JOBS=1

# Production: xtts_gpu. Tests/local smoke: mock.
TTS_ENGINE=xtts_gpu

# Fine-tuned XTTSv2 model. Use one of:
# - Hugging Face repo id: aiMy144/XTTSv2VietAudiobook
# - local folder: models/model
# - local checkpoint: models/model/model.pth
# Leave empty to use the built-in Hugging Face default above.
XTTS_MODEL_NAME_OR_PATH=aiMy144/XTTSv2VietAudiobook
XTTS_CONFIG_PATH=
XTTS_VOCAB_PATH=
XTTS_RUNTIME_DIR=models/XTTSv2-Finetuning-for-New-Languages
XTTS_VOICE_DIR=data/voice_samples

# Required only for private Hugging Face repos
HF_TOKEN=

# VieNeu PyTorch backbone + optional LoRA adapter.
# LoRA adapters require the PyTorch backbone and are not supported with GGUF models.
TTS_DEVICE=cpu
VIENEU_DEVICE=cpu
VIENEU_MODEL_NAME=pnnbao-ump/VieNeu-TTS-v2
VIENEU_LORA_ADAPTER=
VIENEU_MODE=standard
VIENEU_EMOTION=storytelling
