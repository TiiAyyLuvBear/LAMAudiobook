# Environment Configuration Example
# Copy this file to .env and update values

# Application
DEBUG=True
ENVIRONMENT=development

# Database
DATABASE_URL=sqlite:///news_portal.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost/dbname
# For MySQL: DATABASE_URL=mysql+pymysql://user:password@localhost/dbname

# API
API_V1_PREFIX=/api/v1

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Pagination
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# News Settings
FEATURED_NEWS_LIMIT=5
TRENDING_NEWS_LIMIT=5
